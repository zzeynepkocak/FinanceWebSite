# ── Keycloak ──────────────────────────────────────────────────────────────
# docker compose up sonrası Keycloak http://localhost:8080'de çalışır
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=toyota-finance
VITE_KEYCLOAK_CLIENT=finance-portal-app

# ── Backend API ────────────────────────────────────────────────────────────
VITE_API_BASE=http://localhost:8081

# ── Finnhub gerçek zamanlı piyasa verisi ──────────────────────────────────
VITE_FINNHUB_API_KEY=your_finnhub_api_key_here

# ── Mock Auth ─────────────────────────────────────────────────────────────
# true  → Keycloak olmadan giriş yapılabilir (local development)
# false → Gerçek Keycloak SSO kullanılır (docker compose çalışıyor olmalı)
VITE_MOCK_AUTH=true
